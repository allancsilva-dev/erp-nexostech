NODE_ENV=development
PORT=3001

# Database (PostgreSQL externo via gateway Docker)
DATABASE_URL=postgresql://postgres:postgres@172.17.0.1:32770/nexos_erp
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000

# Redis
REDIS_URL=redis://:redis@redis:6379

# Auth (ZonaDev)
AUTH_JWKS_URL=https://auth.zonadev.tech/.well-known/jwks.json
AUTH_JWT_AUDIENCE=erp.zonadev.tech
AUTH_JWT_ISSUER=auth.zonadev.tech
AUTH_AUDIENCE=erp.zonadev.tech
AUTH_ISSUER=https://auth.zonadev.tech

# Optional integrations
BOLETOS_GATEWAY_URL=https://boletos.local
R2_ACCOUNT_ID=
R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=nexos-files
R2_PUBLIC_BASE_URL=https://files.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BOLETO_GATEWAY=asaas
ASAAS_API_KEY=
EFI_API_KEY=
IUGU_API_KEY=
SENTRY_DSN=

# Observability
OTEL_ENABLED=true
LOG_LEVEL=info
