NODE_ENV=development
PORT=3001

# Database (pgBouncer transaction pooling recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:6432/nexos_erp
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000

# Redis
REDIS_URL=redis://localhost:6379

# Auth (ZonaDev)
AUTH_JWKS_URL=https://auth.zonadev.tech/.well-known/jwks.json
AUTH_AUDIENCE=erp.zonadev.tech
AUTH_ISSUER=https://auth.zonadev.tech

# Optional integrations
BOLETOS_GATEWAY_URL=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
BOLETO_GATEWAY=asaas
ASAAS_API_KEY=
EFI_API_KEY=
IUGU_API_KEY=

# Observability
OTEL_ENABLED=true
LOG_LEVEL=info
